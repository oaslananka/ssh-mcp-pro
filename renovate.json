{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "schedule:weekly",
    ":separateMajorReleases"
  ],
  "labels": [
    "dependencies"
  ],
  "prHourlyLimit": 2,
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "matchPackageNames": [
        "@modelcontextprotocol/sdk"
      ],
      "automerge": false
    },
    {
      "description": "Keep parser and rule package updates together.",
      "matchPackageNames": [
        "@typescript-eslint/eslint-plugin",
        "@typescript-eslint/parser"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "typescript-eslint packages"
    },
    {
      "matchManagers": [
        "github-actions"
      ],
      "addLabels": [
        "ci"
      ]
    }
  ]
}
